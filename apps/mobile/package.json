{
  "name": "@personal/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "go:testflight": "eas go --bundle-id \"${EXPO_GO_BUNDLE_ID:-com.nandcello.juicecolored.expogo55}\" --name \"${EXPO_GO_APP_NAME:-Juicecolored Expo Go}\"",
    "build:device:ios": "eas build --platform ios --profile production-device",
    "build:device:android": "eas build --platform android --profile production-device",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@personal/convex": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "convex": "^1.37.0",
    "expo": "~55.0.24",
    "expo-linking": "~55.0.15",
    "expo-location": "^55.1.10",
    "expo-router": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-updates": "~55.0.22",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "uniwind": "^1.6.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2"
  }
}
