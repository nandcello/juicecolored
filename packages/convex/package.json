    },
    "./dataModel": {
      "types": "./convex/_generated/dataModel.d.ts"
    }
  },
  "scripts": {
    "dev": "bun --env-file=../../.env.local convex dev",
    "codegen": "bun --env-file=../../.env.local convex codegen",
    "deploy": "bun --env-file=../../.env.local convex deploy"
